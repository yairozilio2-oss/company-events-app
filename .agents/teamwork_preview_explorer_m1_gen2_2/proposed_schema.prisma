model User {
  id               Int            @id @default(autoincrement())
  email            String         @unique
  name             String
  passwordHash     String
  gender           String
  role             String         @default("employee")
  registrations    Registration[]
  sentRequests     Preference[]   @relation("Requester")
  receivedRequests Preference[]   @relation("Requested")
}

model Event {
  id            Int            @id @default(autoincrement())
  name          String
  date          DateTime
  location      String
  rooms         Room[]
  registrations Registration[]
  preferences   Preference[]
}

model Registration {
  id           Int      @id @default(autoincrement())
  userId       Int
  eventId      Int
  user         User     @relation(fields: [userId], references: [id])
  event        Event    @relation(fields: [eventId], references: [id])
  roomId       Int?
  room         Room?    @relation(fields: [roomId], references: [id])
  kosherFood   Boolean  @default(false)
  arrivalTime  String?

  @@unique([userId, eventId])
}

model Room {
  id            Int            @id @default(autoincrement())
  capacity      Int
  gender        String         // "M", "F", or "Mixed"
  eventId       Int
  event         Event          @relation(fields: [eventId], references: [id])
  registrations Registration[]
}

model Preference {
  id          Int    @id @default(autoincrement())
  requesterId Int
  requestedId Int
  eventId     Int
  status      String @default("pending") // "pending", "approved", "rejected"
  
  requester   User   @relation("Requester", fields: [requesterId], references: [id])
  requested   User   @relation("Requested", fields: [requestedId], references: [id])
  event       Event  @relation(fields: [eventId], references: [id])
}
